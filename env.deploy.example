# Docker Deployment Configuration
# Copy this file to .env.deploy and fill in your values
# WARNING: Keep this file secure - it contains Docker Hub credentials
# This file is used by: xmerch deploy --docker

# ===================
# Docker Hub Configuration
# ===================
# Required for pushing Docker images to Docker Hub
# Create account at: https://hub.docker.com
# Create Personal Access Token: https://hub.docker.com/settings/security

DOCKER_USERNAME=your-dockerhub-username
DOCKER_PERSONAL_ACCESS_TOKEN=your-dockerhub-token-here

# Optional: Override default registry (defaults to docker.io)
# DOCKER_REGISTRY=docker.io

# Optional: Override namespace (defaults to DOCKER_USERNAME)
# DOCKER_NAMESPACE=your-dockerhub-username

# ===================
# Docker Image Configuration
# ===================
# Tag for your Docker image (defaults to 'latest')
DEPLOY_TAG=latest

# ===================
# Build Arguments for Next.js
# ===================
# These are bundled into the Docker image at BUILD time
# Must match your deployed environment

# Your deployed domain (Evernode, Vercel, or custom)
NEXT_PUBLIC_BASE_URL=https://xbase.zerp.network

# Supabase project configuration
# Note: Anon key is safe to be public - RLS protects your data
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ===================
# Evernode Deployment Example
# ===================
# After building and pushing with 'xmerch deploy --docker':
# Deploy to Evernode with:
#   mworksusa/xbase_v2:latest--gptcp1--3000--subdomain--xbase--proxyssl--false
#
# This creates: https://xbase.zerp.network
