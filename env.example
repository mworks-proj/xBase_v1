# xBase Environment Variables
# Copy this file to .env.local and fill in your values

# ===================
# Supabase Configuration
# ===================
# Get these from: Supabase Dashboard > Settings > API
# These are bundled into your app at build time and protected by RLS policies
# Note: Anon key is safe to be public - RLS protects your data

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ===================
# App Configuration
# ===================
# Your app's base URL (used for webhooks and return URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ===================
# Supabase Edge Function Secrets (Server-side ONLY)
# ===================
# Set these in Supabase Dashboard > Project Settings > Edge Functions > Secrets
# These are NEVER in Docker or your .env file - they live in Supabase Vault only
# 
# Required secrets to set in Supabase:
# - XUMM_API_KEY (for Xahau payments)
# - XUMM_API_SECRET (for Xahau payments)
# - XAH_DESTINATION (your Xahau address)
# - XUMM_API_KEY_XRPL (for XRPL payments)
# - XUMM_API_SECRET_XRPL (for XRPL payments)
# - XRP_DESTINATION (your XRPL address)
# - SUPABASE_SERVICE_ROLE_KEY (for database writes from webhook)
